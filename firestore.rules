rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Returns true when the caller is the GM of any campaign in the supplied list.
    function isGM(campaignIds) {
      return isSignedIn()
        && campaignIds is list
        && campaignIds.size() > 0
        && campaignIds.hasAny(
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gmCampaignIds
           );
    }

    // ------------------------------------------------------------------
    // users/{uid} — caller can only touch their own user doc
    // ------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if isSelf(uid);
    }

    // ------------------------------------------------------------------
    // campaigns/{campaignId}
    //   read: GM or any roster member (uid present in playerUids — a
    //         denormalized array maintained by the campaign Server Actions)
    //   write: forbidden — Server Actions via Admin SDK only.
    // ------------------------------------------------------------------
    match /campaigns/{campaignId} {
      allow read: if isSignedIn() && (
        resource.data.gmUid == request.auth.uid
        || (resource.data.playerUids is list
            && resource.data.playerUids.hasAny([request.auth.uid]))
      );
      allow write: if false;

      // challenges subcollection — GM-only read; writes go through Admin SDK.
      match /challenges/{challengeId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmUid == request.auth.uid;
        allow write: if false;
      }

      // sessionLog subcollection — any campaign member reads; writes via
      // Admin SDK only (auto-emitted by host actions + manual annotations).
      match /sessionLog/{entryId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmUid == request.auth.uid
          || (request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.playerUids)
        );
        allow write: if false;
      }

      // engagedChallenges mirror — denormalized player-visible subset of an
      // engaged challenge. Any member reads; writes via Admin SDK only.
      match /engagedChallenges/{challengeId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmUid == request.auth.uid
          || (request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.playerUids)
        );
        allow write: if false;
      }

      // pendingThreats — reaction state machine. Any member reads (UI
      // branches on role); writes via Admin SDK only.
      match /pendingThreats/{ptId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmUid == request.auth.uid
          || (request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.playerUids)
        );
        allow write: if false;
      }
    }

    // ------------------------------------------------------------------
    // characters/{charId}
    //   own character: full r/w (data.userId == uid)
    //   GM of any of the character's campaigns: full r/w (to apply consequences)
    //   delete: forbidden — explicit Server Action only.
    // ------------------------------------------------------------------
    match /characters/{charId} {
      function ownerMatches() {
        return resource.data.userId == request.auth.uid;
      }

      allow read, update: if isSignedIn() && (
        ownerMatches() || isGM(resource.data.campaignIds)
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;

      // rolls subcollection — server-written via Admin SDK only; clients read.
      match /rolls/{rollId} {
        function parentChar() {
          return get(/databases/$(database)/documents/characters/$(charId)).data;
        }
        allow read: if isSignedIn() && (
          parentChar().userId == request.auth.uid
          || isGM(parentChar().campaignIds)
        );
        allow write: if false;
      }
    }

    // ------------------------------------------------------------------
    // invitations/{invitationId}
    //   get: any signed-in user (so they can land on /invite/[token]).
    //   list: only allowed when filtering by campaignId AND the user is the
    //         GM of that campaign. Combined with a where("campaignId", "==",
    //         X) on the client this restricts enumeration to GMs.
    //   write: forbidden — Server Actions via Admin SDK only.
    // ------------------------------------------------------------------
    match /invitations/{invitationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && resource.data.campaignId is string
        && get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)).data.gmUid == request.auth.uid;
      allow write: if false;
    }

    // ------------------------------------------------------------------
    // challenges/{challengeId} — GM-only, never readable by players
    // ------------------------------------------------------------------
    match /challenges/{challengeId} {
      allow read, update, delete: if isSignedIn()
        && resource.data.gmId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.gmId == request.auth.uid;
    }

    // Default deny — every other path is forbidden.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
