rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    /* =========================
       Helpers
    ========================== */

    // App Check enforcement on Storage is currently OFF because the SDK
    // intermittently fails to attach the token (works for Firestore via the
    // same initializeAppCheck instance — to investigate). Other guards (auth,
    // owner, MIME, size) stay in place.
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isAllowedFileSize() {
      // 2MB max
      return request.resource.size < 2 * 1024 * 1024;
    }

    function isSafeContentType() {
      return request.resource.contentType.matches(
        'image/jpeg|image/png|image/webp'
      );
    }

    /* =========================
       User private uploads
    ========================== */

    match /users/{userId}/{allPaths=**} {

      // Reads are unconditional for now — we want owners to be able to
      // fetch their uploaded avatars via getDownloadURL. The MIME/size
      // guards are write-only since `request.resource` is null on reads
      // and would otherwise nullify the predicate.
      allow read: if isAuthenticated() && isOwner(userId);

      allow write:
        if isAuthenticated()
        && isOwner(userId)
        && isImage()
        && isSafeContentType()
        && isAllowedFileSize();
    }

    /* =========================
       Completely block everything else
    ========================== */

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
